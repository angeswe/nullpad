# Admin identity (generate with openssl, see README.md)
ADMIN_PUBKEY=
ADMIN_ALIAS=admin

# Redis (REDIS_PASSWORD is required — docker-compose will fail without it)
REDIS_PASSWORD=
REDIS_URL=redis://:<redis password>@redis:6379

# Server
BIND_ADDR=0.0.0.0:3000

# Storage
PASTE_STORAGE_PATH=/data/pastes

# Limits
MAX_UPLOAD_BYTES=52428800

# TTLs
DEFAULT_TTL_SECS=86400
MAX_TTL_SECS=604800
INVITE_TTL_SECS=43200
USER_IDLE_TTL_SECS=172800
USER_ACTIVE_TTL_SECS=86400
SESSION_TTL_SECS=900
CHALLENGE_TTL_SECS=30

# Rate limiting
RATE_LIMIT_PASTE_PER_MIN=10
RATE_LIMIT_AUTH_PER_MIN=5

# Proxy configuration
# Number of trusted reverse proxies in front of the application.
# Used to extract the real client IP from X-Forwarded-For header
# (nth-from-right). Set to 0 if not behind a proxy.
TRUSTED_PROXY_COUNT=0

# Session management
MAX_SESSIONS_PER_USER=5

# Per-user paste limit (0 = unlimited)
MAX_PASTES_PER_USER=50

# Tor / onion deployment toggle (default false).
# When true, the Secure flag is omitted from the session cookie. Tor provides
# end-to-end transport encryption to the hidden service, and browsers silently
# discard Secure cookies over plain HTTP (which is how a .onion address is
# reached inside the Tor network). DO NOT enable on clearnet deployments —
# the Secure flag protects clearnet users from MITM cookie theft.
ONION_MODE=false
